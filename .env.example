# ==========================================
# Dr. Coxinha — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ==========================================

# Porta do servidor (Render define automaticamente)
PORT=3000

# Segurança — troque por uma string longa e aleatória em produção
JWT_SECRET=troque-por-uma-chave-segura-em-producao

# Senha inicial do admin (gerada no primeiro start se usuarios.json estiver vazio)
ADMIN_PASSWORD=admin123

# CORS — em produção, coloque a URL do seu site (ex: https://dr-coxinha.onrender.com)
CORS_ORIGIN=*

# Firebase Admin SDK (push notifications)
# Cole o JSON completo do arquivo serviceAccountKey.json como string de uma linha
# Veja MANUAL_FIREBASE.md para instruções
FIREBASE_ADMIN_SDK_JSON=

# Diretório do banco de dados (padrão: backend/src/database/)
# No Render com disco persistente: /data/database
DB_DIR=
